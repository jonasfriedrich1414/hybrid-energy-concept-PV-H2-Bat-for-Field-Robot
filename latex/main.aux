\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Flowchart eines Simulationsschritts. Zunächst wird die Last um die PV-Erzeugung und die Brennstoffzellenleistung reduziert. Eine verbleibende Leistungsdifferenz wird durch die Batterie ausgeglichen. Danach wird die Brennstoffzellenleistung für den nächsten Iterationsschritt bestimmt.}}{14}{figure.caption.17}\protected@file@percent }
\newlabel{fig:flowchart}{{7}{14}{Flowchart eines Simulationsschritts. Zunächst wird die Last um die PV-Erzeugung und die Brennstoffzellenleistung reduziert. Eine verbleibende Leistungsdifferenz wird durch die Batterie ausgeglichen. Danach wird die Brennstoffzellenleistung für den nächsten Iterationsschritt bestimmt}{figure.caption.17}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.4.3}FC Leistungsregelung am Tag}{15}{subsubsection.3.4.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.4.4}FC Leistungsregelung in der Nacht}{15}{subsubsection.3.4.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Parameter der Brennstoffzellenregelung. Die Brennstoffzelle schaltet sich anhand des Batteriefüllstands ein und aus. Für die Leistungsanpassung wird über die letzten fünf Minuten die Residuallast gemittelt. Das Zeitfenster des Nachtbetriebs wird um eine Stunde in den Tag hinein verlängert. In der Nacht wird die Brennstoffzelle so betrieben, dass die Batterie am Morgen noch einen Füllstand von 30~\% hat.}}{16}{table.caption.18}\protected@file@percent }
\newlabel{tab:paramregelung}{{6}{16}{Parameter der Brennstoffzellenregelung. Die Brennstoffzelle schaltet sich anhand des Batteriefüllstands ein und aus. Für die Leistungsanpassung wird über die letzten fünf Minuten die Residuallast gemittelt. Das Zeitfenster des Nachtbetriebs wird um eine Stunde in den Tag hinein verlängert. In der Nacht wird die Brennstoffzelle so betrieben, dass die Batterie am Morgen noch einen Füllstand von 30~\% hat}{table.caption.18}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Aus- und Einschaltparameter. Der Feldroboter schaltet sich abhängig vom Füllstand der Batterie an und aus.}}{16}{table.caption.19}\protected@file@percent }
