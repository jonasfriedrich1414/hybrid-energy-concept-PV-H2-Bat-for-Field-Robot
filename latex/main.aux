\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Shapiro-Wilk Test zum Hypthesentest auf Normalverteilung. Bei p-Werten unter 0,05 muss die Annahme einer Normalverteilung verworfen werden. Dies trifft auf die Global- und Direktstrahlung zu. Bei der Diffusstrahlung kann die Normalverteilung hingegen nicht verworfen werden. Daraus ergibt sich, dass die Energieversorgungwahrscheinlichkeiten durch die Globalstrahlung nicht mit Standardabweichungen angegeben werden können.}}{20}{figure.caption.24}\protected@file@percent }
\newlabel{fig:p-Wert_overview}{{10}{20}{Shapiro-Wilk Test zum Hypthesentest auf Normalverteilung. Bei p-Werten unter 0,05 muss die Annahme einer Normalverteilung verworfen werden. Dies trifft auf die Global- und Direktstrahlung zu. Bei der Diffusstrahlung kann die Normalverteilung hingegen nicht verworfen werden. Daraus ergibt sich, dass die Energieversorgungwahrscheinlichkeiten durch die Globalstrahlung nicht mit Standardabweichungen angegeben werden können}{figure.caption.24}{}}
